APP_NAME=TabResolver
UID=1000
GID=1000
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Host-side ports exposed by docker-compose (left side of host:container).
# Change these to avoid clashes with other running containers.
# They do NOT affect the internal ports the app uses over the Docker network.
FORWARD_APP_PORT=8080
FORWARD_DB_PORT=3307
FORWARD_REDIS_PORT=6380
# Vite dev server (HMR) — published by the `vite` compose service
FORWARD_VITE_PORT=5173

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=tabresolve
DB_USERNAME=tabresolve
DB_PASSWORD=secret

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_QUEUE_RETRY_AFTER=150
PULSE_SLOW_JOBS_THRESHOLD=1000

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_CONNECTION=reverb

# Logs are written daily (storage/logs/laravel-YYYY-MM-DD.log) and pruned after
# LOG_DAILY_DAYS days. The "Log" admin page reads these files.
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@tabresolve.app"
MAIL_FROM_NAME="${APP_NAME}"

OPENAI_API_KEY=
OPENAI_RECEIPT_MODEL=gpt-4o-mini
OPENAI_AUDIO_MODEL=whisper-1

# Admin inicial criado pelo AdminUserSeeder (php artisan db:seed).
# Defina email e senha para liberar o acesso à página de Integrações.
ADMIN_NAME=Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Host-side port for Reverb websocket server (exposed by docker-compose)
FORWARD_REVERB_PORT=8081

# REVERB_APP_KEY/SECRET are dev placeholders — REQUIRED: set strong random values
# before any internet-accessible deployment (the secret signs private-channel auth).
REVERB_APP_ID=tabresolver
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=change-me-in-production
REVERB_HOST=localhost
REVERB_PORT=8081
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
